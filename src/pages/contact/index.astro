---
import BaseLayout from '@/layouts/BaseLayout.astro';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<BaseLayout
  title="Contact"
  description="Contact Daniel Edmund Rochatka about software architecture, product engineering, AI systems, research, or professional collaboration."
>
  <section class="contact-page section-pad">
    <p class="eyebrow">Contact</p>
    <h1>Start with the subject, context, and decision you are trying to make.</h1>
    <p>For direct professional or research correspondence, use the form below. The receiving address is kept private.</p>

    <noscript>
      <style>#contact-form { display: none; }</style>
      <p>JavaScript is required to submit this contact form. Please enable JavaScript in your browser and reload the page.</p>
    </noscript>

    {turnstileSiteKey ? (
      <form class="contact-form" id="contact-form" action="/api/contact" method="post" novalidate data-turnstile-site-key={turnstileSiteKey}>
        <div class="form-field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" autocomplete="name" required minlength="2" maxlength="100" aria-describedby="name-error" />
          <p class="field-error" id="name-error"></p>
        </div>

        <div class="form-field">
          <label for="email">Reply email</label>
          <input id="email" name="email" type="email" autocomplete="email" required maxlength="254" aria-describedby="email-error" />
          <p class="field-error" id="email-error"></p>
        </div>

        <div class="form-field">
          <label for="subject">Subject <span class="field-optional">— optional</span></label>
          <input id="subject" name="subject" type="text" maxlength="120" aria-describedby="subject-error" />
          <p class="field-error" id="subject-error"></p>
        </div>

        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="7" required minlength="10" maxlength="5000" aria-describedby="message-error"></textarea>
          <p class="field-error" id="message-error"></p>
        </div>

        <div class="form-field form-field--honeypot" aria-hidden="true">
          <label for="website">Website</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <input type="hidden" name="_formStart" id="form-start" />

        <div class="form-field">
          <div id="turnstile-widget" aria-label="Human verification"></div>
        </div>

        <div class="form-actions">
          <button class="button primary" type="submit" data-default-text="Send message" data-sending-text="Sending…" disabled>Send message</button>
          <p class="form-status" id="contact-status" role="status" aria-live="polite"></p>
        </div>
      </form>
      <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    ) : (
      <p class="form-status form-status--error" role="status">The contact form is unavailable. Please try again later.</p>
    )}

    <div class="contact-boundary">
      <strong>Company inquiries</strong>
      <p>For Procyonsoft services or company matters, use the separate corporate site.</p>
      <a class="text-link" href="https://procyonsoft.com/contact/">Visit Procyonsoft contact <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <script is:inline>
    const form = document.querySelector('#contact-form');
    const status = document.querySelector('#contact-status');
    const submit = form?.querySelector('button[type="submit"]');
    const fields = ['name', 'email', 'subject', 'message'];
    const formStartInput = document.querySelector('#form-start');
    const turnstileContainer = document.querySelector('#turnstile-widget');
    let turnstileToken = '';
    let turnstileWidgetId;
    let submitting = false;

    function resetFormStart() {
      if (formStartInput) formStartInput.value = String(Date.now());
    }
    resetFormStart();

    function updateSubmitState() {
      if (!submit) return;
      submit.disabled = submitting || !turnstileToken;
      submit.textContent = submitting ? submit.dataset.sendingText : submit.dataset.defaultText;
    }

    function resetTurnstile() {
      turnstileToken = '';
      if (window.turnstile && turnstileWidgetId !== undefined) window.turnstile.reset(turnstileWidgetId);
      updateSubmitState();
    }

    function verificationRetryMessage() {
      status.textContent = 'Verification is unavailable. Please retry verification and submit again.';
      status.className = 'form-status form-status--error';
    }

    window.onDanielTurnstileSuccess = (token) => {
      turnstileToken = token || '';
      updateSubmitState();
    };
    window.onDanielTurnstileExpired = () => { resetTurnstile(); verificationRetryMessage(); };
    window.onDanielTurnstileError = () => { resetTurnstile(); verificationRetryMessage(); };

    function renderTurnstile() {
      if (!form || !turnstileContainer || !window.turnstile) return;
      turnstileWidgetId = window.turnstile.render(turnstileContainer, {
        sitekey: form.dataset.turnstileSiteKey,
        callback: window.onDanielTurnstileSuccess,
        'expired-callback': window.onDanielTurnstileExpired,
        'error-callback': window.onDanielTurnstileError,
      });
      updateSubmitState();
    }

    if (form) {
      const timer = setInterval(() => {
        if (window.turnstile) { clearInterval(timer); renderTurnstile(); }
      }, 50);
    }

    function setErrors(errors = {}) {
      for (const field of fields) {
        const input = form.querySelector(`[name="${field}"]`);
        const error = document.querySelector(`#${field}-error`);
        const message = errors[field] || '';
        if (error) error.textContent = message;
        if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      setErrors();
      if (!turnstileToken) { verificationRetryMessage(); updateSubmitState(); return; }
      status.textContent = 'Sending your message…';
      status.className = 'form-status';
      submitting = true;
      updateSubmitState();

      const payload = Object.fromEntries(new FormData(form).entries());
      payload['cf-turnstile-response'] = turnstileToken;
      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json().catch(() => ({}));
        if (response.ok && result.ok) {
          form.reset();
          resetFormStart();
          status.textContent = result.message || 'Thank you. Your message has been sent.';
          status.classList.add('form-status--success');
          setErrors();
          resetTurnstile();
          return;
        }
        if (result.errors) setErrors(result.errors);
        status.textContent = result.message || 'Verification is unavailable. Please retry verification and submit again.';
        status.classList.add('form-status--error');
        resetTurnstile();
      } catch {
        status.textContent = 'Verification is unavailable. Please retry verification and submit again.';
        status.classList.add('form-status--error');
        resetTurnstile();
      } finally {
        submitting = false;
        updateSubmitState();
      }
    });
  </script>
</BaseLayout>
