DANIEL_RESEND_API_KEY=re_replace_me
DANIEL_CONTACT_FROM="Daniel Rochatka Website <verified-sender@example.com>"
DANIEL_CONTACT_TO=private-destination@example.com
PUBLIC_TURNSTILE_SITE_KEY=replace_me
TURNSTILE_SECRET_KEY=replace_me
DANIEL_CONTACT_HOST=127.0.0.1
DANIEL_CONTACT_PORT=8788

# Optional — defaults shown
DANIEL_ALLOWED_ORIGINS=https://daniel.rochatka.com,https://www.daniel.rochatka.com
DANIEL_MIN_SUBMIT_SECONDS=2
DANIEL_IP_RATE_LIMIT=3
DANIEL_GLOBAL_BURST_LIMIT=20
DANIEL_DUPLICATE_WINDOW_HOURS=24

# Normal contact path: no visitor acknowledgement email or webhook tracking.
DANIEL_ACK_ENABLED=false
# Optional legacy acknowledgement/webhook settings, needed only if DANIEL_ACK_ENABLED=true.
DANIEL_EMAIL_ACK_LIMIT=2
DANIEL_CONTACT_DATA_DIR=/var/lib/daniel-rochatka-contact
DANIEL_RESEND_WEBHOOK_SECRET=whsec_replace_me
